+		},
+		CliOption {
+			.long_option = "skipverify",
+			.description = "Skip certificate verification",
+		},
+		CliOption {
+			.long_option = "version",
+			.short_option = "v",
+			.description = "Print version and exit",
+		},
+		help_option,
+	};
+	return common_global_options;
+}
 
